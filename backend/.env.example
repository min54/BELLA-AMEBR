# ----- Core -----
APP_NAME="Bella Korea Ambassador API"
DEBUG=false

# ----- Database -----
# SQLite file path (relative to /backend). For Postgres: postgresql+psycopg://user:pass@host/db
DATABASE_URL=sqlite:///./bella.db

# ----- CORS -----
# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000

# ----- Resend (preferred for production) -----
# Sign up at https://resend.com, create an API key. Leave blank to fall back
# to SMTP. Required when hosting on PaaS platforms that block outbound SMTP
# (Render free tier, Vercel, etc).
RESEND_API_KEY=
# Default sender. Use "onboarding@resend.dev" for quick setup without domain
# verification (can only send to the Resend account owner's email address).
# Once you verify a domain on Resend, replace this with e.g. "no-reply@yourdomain.com".
RESEND_FROM=onboarding@resend.dev

# ----- SMTP (local-dev fallback) -----
# Used only when RESEND_API_KEY is empty. All four (host/user/password + from) must be set.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
MAIL_FROM=
# Comma-separated list of recipient addresses (e.g. admin@foo.com,manager@foo.com)
MAIL_TO=
