# ----- Core -----
APP_NAME="Bella Korea Ambassador API"
DEBUG=false

# ----- Database -----
# SQLite file path (relative to /backend). For Postgres: postgresql+psycopg://user:pass@host/db
DATABASE_URL=sqlite:///./bella.db

# ----- CORS -----
# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000

# ----- SMTP (optional) -----
# Leave blank to disable email notifications. All four (host/user/password + from/to) must be set.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
MAIL_FROM=
# Comma-separated list of recipient addresses (e.g. admin@foo.com,manager@foo.com)
MAIL_TO=
